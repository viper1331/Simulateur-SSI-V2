{
  "name": "simu-ssi",
  "private": true,
  "version": "0.1.7",
  "packageManager": "pnpm@8.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev": "pnpm --filter server run prisma:migrate-deploy && pnpm run dev:workspace",
    "dev:workspace": "pnpm run build:packages && pnpm -r --parallel dev",
    "format": "pnpm -r format",
    "typecheck": "pnpm -r typecheck",
    "prisma:generate": "pnpm --filter server run prisma:generate",
    "prisma:migrate": "pnpm --filter server run prisma:migrate",
    "build:packages": "pnpm --filter \"./packages/*\" run build",
    "security:integrate-auth": "node scripts/integrate-api-auth.mjs",
    "security:integrate-client-auth": "node scripts/integrate-client-auth.mjs",
    "security:integrate-hashed-access-codes": "node scripts/integrate-hashed-access-codes.mjs"
  }
}
