DATABASE_URL="file:./dev.db"

# Optional API security layer.
# Leave disabled for local prototype usage.
# Set to true when the server is exposed outside localhost or a trusted lab network.
SIMU_SSI_AUTH_REQUIRED="false"

# Legacy single admin token. Prefer SIMU_SSI_API_TOKENS for role separation.
# SIMU_SSI_API_TOKEN="change-me-admin-token"

# Comma-separated role-scoped tokens.
# Supported roles: ADMIN, TRAINER, TRAINEE.
# Example:
# SIMU_SSI_API_TOKENS="ADMIN:change-me-admin-token,TRAINER:change-me-trainer-token,TRAINEE:change-me-trainee-token"
