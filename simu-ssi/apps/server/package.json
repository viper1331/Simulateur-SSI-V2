{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "prisma migrate deploy",
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --dts",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate",
    "prisma:migrate-deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "@simu-ssi/domain-ssi": "workspace:*",
    "@simu-ssi/sdk": "workspace:*",
    "cors": "^2.8.5",
    "eventemitter3": "^5.0.1",
    "express": "^4.18.2",
    "http": "^0.0.1-security",
    "pdfkit": "^0.17.2",
    "socket.io": "^4.7.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.17",
    "@types/pdfkit": "^0.17.3",
    "@types/supertest": "^2.0.15",
    "jest": "^29.7.0",
    "prisma": "^5.10.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsup": "^7.2.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
